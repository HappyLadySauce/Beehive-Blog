<%
const ph = theme.post_header || {};
let postHeroCover = '';
if (page.layout === 'post' && ph.enable !== false && page.top_img !== false) {
  postHeroCover = page.top_img || page.cover || page.banner || ph.default_cover || (theme.seo && theme.seo.og_image) || '';
}
const showPostHero = !!(page.layout === 'post' && postHeroCover);
const bodyClasses = ['layout-' + (page.layout || 'default')];
if (showPostHero) bodyClasses.push('has-post-hero');
%>
<!DOCTYPE html>
<html lang="<%= Array.isArray(config.language) ? config.language[0] : (config.language || 'zh-CN') %>" data-theme="light">
<head>
  <%- partial('partials/head') %>
</head>
<body class="<%= bodyClasses.join(' ') %>">
  <script>
    window.__HLS_THEME__ = {
      defaultTheme: "<%= theme.appearance && theme.appearance.default_theme ? theme.appearance.default_theme : 'auto' %>",
      accent: "<%= theme.appearance && theme.appearance.accent ? theme.appearance.accent : '#3b82f6' %>"
    };
    window.__BEEHIVE_API_BASE__ = "<%= theme.beehive && theme.beehive.api_base ? theme.beehive.api_base : '' %>";
  </script>
  <div class="site-shell">
    <div id="body-wrap">
      <% if (showPostHero) { %>
        <%- partial('partials/post-page-header', { postHeroCover: postHeroCover }) %>
      <% } else { %>
        <%- partial('partials/nav') %>
      <% } %>
      <main class="site-main">
        <%- body %>
      </main>
    </div>
    <%- partial('partials/footer') %>
  </div>
  <script src="<%- url_for('/js/theme.js') %>"></script>
  <script src="<%- url_for('/js/code-block-ui.js') %>"></script>
  <% if (theme.beehive && theme.beehive.enable_auth) { %>
    <script src="<%- url_for('/js/beehive-auth.js') %>"></script>
  <% } %>
  <script src="<%- url_for('/js/beehive-comments.js') %>"></script>
  <script type="module" src="<%- url_for('/js/pretext-enhance.js') %>"></script>
</body>
</html>
