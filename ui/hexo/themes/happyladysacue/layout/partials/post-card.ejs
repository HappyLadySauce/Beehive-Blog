<%
const currentPost = post;
const excerpt = String(currentPost.excerpt || currentPost.content || '')
  .replace(/<[^>]*>/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();
const firstCategory = currentPost.categories && currentPost.categories.length
  ? currentPost.categories.data[0].name
  : '未分类';
const cover = currentPost.cover || currentPost.banner || '';
const views = currentPost.views || 0;
const dateStr = date(currentPost.date, config.date_format || 'YYYY-MM-DD');
%>
<article class="post-card">
  <%# 封面图或渐变占位 %>
  <% if (cover) { %>
    <a class="post-card__cover" href="<%- url_for(currentPost.path) %>" aria-hidden="true" tabindex="-1">
      <span class="post-card__tag"><%= firstCategory %></span>
      <img src="<%- url_for(cover) %>" alt="<%= currentPost.title %>" loading="lazy">
    </a>
  <% } else { %>
    <a class="post-card__cover post-card__cover--placeholder" href="<%- url_for(currentPost.path) %>" aria-hidden="true" tabindex="-1">
      <span class="post-card__tag"><%= firstCategory %></span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
    </a>
  <% } %>

  <div class="post-card__body">
    <div class="post-card__meta">
      <time datetime="<%= date_xml(currentPost.date) %>">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" style="display:inline;vertical-align:middle;margin-right:2px;">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <%= dateStr %>
      </time>
    </div>

    <h2 class="post-card__title" data-pretext-title>
      <a href="<%- url_for(currentPost.path) %>"><%= currentPost.title %></a>
    </h2>

    <% if (excerpt) { %>
      <p class="post-card__excerpt" data-pretext-excerpt><%= excerpt.slice(0, 120) %></p>
    <% } %>

    <div class="post-card__meta-row">
      <div style="display:flex;gap:10px;align-items:center;">
        <% if (views) { %>
          <span class="post-card__meta-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
            <%= views %>
          </span>
        <% } %>
      </div>
      <a class="post-card__link" href="<%- url_for(currentPost.path) %>">
        阅读更多
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</article>
