<div class="page-single">
  <article class="article-card article-card--page">
    <header class="article-hero article-hero--page">
      <p class="eyebrow">Page</p>
      <h1><%= page.title %></h1>
      <% if (page.description) { %>
        <p class="page-description"><%= page.description %></p>
      <% } %>
    </header>
    <div class="article-content">
      <%- page.content %>
    </div>
  </article>
</div>
