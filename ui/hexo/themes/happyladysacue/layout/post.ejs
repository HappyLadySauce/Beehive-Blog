<%
const tags = page.tags && page.tags.toArray ? page.tags.toArray() : [];
const categories = page.categories && page.categories.toArray ? page.categories.toArray() : [];
const tocCfg = theme.toc || {};
const tocNumber = tocCfg.number !== false;
const tocExpand = tocCfg.expand === true;
const articleToc = toc(page.content || '', { class: 'toc-list', list_number: tocNumber, max_depth: 3 });
const phPost = theme.post_header || {};
let covPost = '';
if (phPost.enable !== false && page.top_img !== false) {
  covPost = page.top_img || page.cover || page.banner || phPost.default_cover || (theme.seo && theme.seo.og_image) || '';
}
const showPostHeroPost = !!covPost;
%>
<div class="page-article">
  <div class="article-shell">
    <article class="article-card">
      <% if (!showPostHeroPost) { %>
      <header class="article-hero">
        <% if (categories.length) { %>
          <p class="eyebrow"><%= categories[0].name %></p>
        <% } else { %>
          <p class="eyebrow">Article</p>
        <% } %>
        <h1><%= page.title %></h1>
        <div class="article-hero__meta">
          <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, config.date_format || 'YYYY-MM-DD') %></time>
          <% if (page.updated) { %>
            <span>更新于 <%= date(page.updated, config.date_format || 'YYYY-MM-DD') %></span>
          <% } %>
        </div>
      </header>
      <% } %>

      <div id="article-container" class="article-content">
        <%- page.content %>
      </div>

      <% if (tags.length) { %>
        <footer class="article-footer">
          <div class="tag-row">
            <% tags.forEach(function (tag) { %>
              <a class="tag-pill" href="<%- url_for(tag.path) %>"># <%= tag.name %></a>
            <% }) %>
          </div>
        </footer>
      <% } %>

      <% const beehiveId = page.beehive_id != null ? page.beehive_id : page['beehive_id']; %>
      <% if (beehiveId != null && String(beehiveId).length) { %>
        <div id="beehive-comments-root"
             class="beehive-comments-root"
             data-beehive-id="<%- String(beehiveId) %>"
             data-api-base="<%- theme.beehive && theme.beehive.api_base ? theme.beehive.api_base : '' %>">
        </div>
      <% } %>
    </article>

    <aside class="article-aside">
      <% if (articleToc) { %>
      <div class="sticky_layout">
        <div id="card-toc" class="card-widget">
          <div class="item-headline">
            <svg class="item-headline-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
              <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
            </svg>
            <span>文章目录</span>
            <span class="toc-percentage" aria-hidden="true"></span>
          </div>
          <div class="toc-content<%- tocExpand ? ' is-expand' : '' %>">
            <%- articleToc %>
          </div>
        </div>
      </div>
      <button type="button"
              class="post-toc-mobile-trigger"
              data-post-toc-trigger
              aria-controls="card-toc"
              aria-expanded="false"
              aria-label="打开文章目录">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
          <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
      </button>
      <% } %>

      <%- partial('partials/sidebar', { hidePostAsideLists: true }) %>
    </aside>
  </div>
</div>
