<%
const tags = site.tags && site.tags.toArray ? site.tags.toArray() : [];
const beehiveTaxTagsPage = site.data.beehive_taxonomy || {};
%>
<div class="page-home">
  <div class="page-header-banner">
    <div class="page-header-banner__inner">
      <p class="eyebrow">Tags</p>
      <h1 class="page-header-banner__title">标签地图</h1>
      <p class="page-header-banner__desc">通过标签交叉浏览不同文章之间的联系与上下文。</p>
    </div>
  </div>

  <div class="taxonomy-open-grid taxonomy-open-grid--tag-cloud">
    <% if (tags.length) { %>
      <div class="tag-cloud tag-cloud--page">
        <% tags.forEach(function (tag) { %>
          <% var act = beehiveTagColorHex(tag, beehiveTaxTagsPage); %>
          <a class="tag-cloud-link<% if (!act) { %> tag-cloud-link--muted<% } %>" href="<%- url_for(tag.path) %>" style="<%- beehiveTagCloudStyle(act) %>"># <%= tag.name %></a>
        <% }) %>
      </div>
    <% } else { %>
      <p style="color:var(--text-muted);">暂无标签。</p>
    <% } %>
  </div>
</div>
