syntax = "v1"

type RegisterRequest {
	username string `json:"username"`
	nickname string `json:"nickname,optional"`
	email    string `json:"email"`
	password string `json:"password"`
}

type LoginRequest {
	account  string `json:"account"`
	password string `json:"password"`
}

type RefreshRequest {
	refreshToken string `json:"refreshToken"`
}

type UserProfile {
	id       int64  `json:"id"`
	username string `json:"username"`
	nickname string `json:"nickname"`
	email    string `json:"email"`
	role     string `json:"role"`
}

type TokenData {
	accessToken  string      `json:"accessToken"`
	refreshToken string      `json:"refreshToken"`
	expiresIn    int64       `json:"expiresIn"`
	user         UserProfile `json:"user"`
}

type ContentSummary {
	id          int64  `json:"id"`
	contentType string `json:"type"`
	title       string `json:"title"`
	slug        string `json:"slug"`
	summary     string `json:"summary"`
	status      string `json:"status"`
	visibility  string `json:"visibility"`
	aiAccess    string `json:"aiAccess"`
	publishedAt string `json:"publishedAt,optional"`
}

type ContentDetail {
	id                   int64                `json:"id"`
	contentType          string               `json:"type"`
	title                string               `json:"title"`
	slug                 string               `json:"slug"`
	summary              string               `json:"summary"`
	bodyMarkdown         string               `json:"bodyMarkdown"`
	status               string               `json:"status"`
	visibility           string               `json:"visibility"`
	aiAccess             string               `json:"aiAccess"`
	projectProfile       ProjectProfile       `json:"projectProfile,optional"`
	experienceProfile    ExperienceProfile    `json:"experienceProfile,optional"`
	timelineEventProfile TimelineEventProfile `json:"timelineEventProfile,optional"`
	portfolioProfile     PortfolioProfile     `json:"portfolioProfile,optional"`
}

type ProjectProfile {
	projectName string `json:"projectName,optional"`
	stack       string `json:"stack,optional"`
	repoUrl     string `json:"repoUrl,optional"`
	demoUrl     string `json:"demoUrl,optional"`
	startedAt   string `json:"startedAt,optional"`
	endedAt     string `json:"endedAt,optional"`
}

type ExperienceProfile {
	orgName   string `json:"orgName,optional"`
	roleName  string `json:"roleName,optional"`
	location  string `json:"location,optional"`
	startedAt string `json:"startedAt,optional"`
	endedAt   string `json:"endedAt,optional"`
}

type TimelineEventProfile {
	eventTime     string `json:"eventTime,optional"`
	eventCategory string `json:"eventCategory,optional"`
}

type PortfolioProfile {
	artifactType string `json:"artifactType,optional"`
	externalLink string `json:"externalLink,optional"`
}

type ContentListRequest {
	page        int64  `form:"page,optional"`
	pageSize    int64  `form:"pageSize,optional"`
	contentType string `form:"type,optional"`
	keyword     string `form:"keyword,optional"`
	status      string `form:"status,optional"`
}

type ContentListResponse {
	list []ContentSummary `json:"list"`
}

type ContentCreateRequest {
	contentType          string               `json:"type"`
	title                string               `json:"title"`
	slug                 string               `json:"slug"`
	summary              string               `json:"summary,optional"`
	bodyMarkdown         string               `json:"bodyMarkdown"`
	visibility           string               `json:"visibility,optional"`
	aiAccess             string               `json:"aiAccess,optional"`
	projectProfile       ProjectProfile       `json:"projectProfile,optional"`
	experienceProfile    ExperienceProfile    `json:"experienceProfile,optional"`
	timelineEventProfile TimelineEventProfile `json:"timelineEventProfile,optional"`
	portfolioProfile     PortfolioProfile     `json:"portfolioProfile,optional"`
	changeNote           string               `json:"changeNote,optional"`
}

type ContentUpdateRequest {
	id                   int64                `path:"id"`
	title                string               `json:"title,optional"`
	summary              string               `json:"summary,optional"`
	bodyMarkdown         string               `json:"bodyMarkdown,optional"`
	visibility           string               `json:"visibility,optional"`
	aiAccess             string               `json:"aiAccess,optional"`
	projectProfile       ProjectProfile       `json:"projectProfile,optional"`
	experienceProfile    ExperienceProfile    `json:"experienceProfile,optional"`
	timelineEventProfile TimelineEventProfile `json:"timelineEventProfile,optional"`
	portfolioProfile     PortfolioProfile     `json:"portfolioProfile,optional"`
	changeNote           string               `json:"changeNote,optional"`
}

type StatusUpdateRequest {
	id     int64  `path:"id"`
	status string `json:"status"`
}

type ContentPathRequest {
	id int64 `path:"id"`
}

type RevisionPathRequest {
	id         int64 `path:"id"`
	revisionId int64 `path:"revisionId"`
}

type RevisionListRequest {
	id       int64 `path:"id"`
	page     int64 `form:"page,optional"`
	pageSize int64 `form:"pageSize,optional"`
}

type RevisionSummary {
	id         int64  `json:"id"`
	contentId  int64  `json:"contentId"`
	version    int64  `json:"version"`
	title      string `json:"title"`
	summary    string `json:"summary"`
	changeNote string `json:"changeNote"`
	createdBy  int64  `json:"createdBy"`
	createdAt  string `json:"createdAt"`
}

type RevisionDetail {
	id           int64  `json:"id"`
	contentId    int64  `json:"contentId"`
	version      int64  `json:"version"`
	title        string `json:"title"`
	summary      string `json:"summary"`
	bodyMarkdown string `json:"bodyMarkdown"`
	changeNote   string `json:"changeNote"`
	createdBy    int64  `json:"createdBy"`
	createdAt    string `json:"createdAt"`
}

type Pagination {
	page      int64 `json:"page"`
	pageSize  int64 `json:"pageSize"`
	total     int64 `json:"total"`
	totalPage int64 `json:"totalPage"`
}

type RevisionListResponse {
	list       []RevisionSummary `json:"list"`
	pagination Pagination        `json:"pagination"`
}

type ReviewTask {
	id              int64  `json:"id"`
	contentId       int64  `json:"contentId"`
	revisionId      int64  `json:"revisionId"`
	submitterUserId int64  `json:"submitterUserId"`
	reviewerUserId  int64  `json:"reviewerUserId"`
	sourceType      string `json:"sourceType"`
	status          string `json:"status"`
	priority        int32  `json:"priority"`
	note            string `json:"note"`
	decidedAt       string `json:"decidedAt,optional"`
	createdAt       string `json:"createdAt"`
	updatedAt       string `json:"updatedAt"`
}

type ReviewListRequest {
	page     int64  `form:"page,optional"`
	pageSize int64  `form:"pageSize,optional"`
	status   string `form:"status,optional"`
}

type ReviewListResponse {
	list       []ReviewTask `json:"list"`
	pagination Pagination   `json:"pagination"`
}

type ContentReviewSubmitRequest {
	id       int64  `path:"id"`
	note     string `json:"note,optional"`
	priority int32  `json:"priority,optional"`
}

type ReviewPathRequest {
	id int64 `path:"id"`
}

type ReviewDecisionRequest {
	id     int64  `path:"id"`
	reason string `json:"reason,optional"`
}

type SearchRequest {
	query       string `form:"query"`
	page        int64  `form:"page,optional"`
	pageSize    int64  `form:"pageSize,optional"`
	contentType string `form:"type,optional"`
}

type SearchResultItem {
	contentId   int64   `json:"contentId"`
	contentType string  `json:"type"`
	title       string  `json:"title"`
	slug        string  `json:"slug"`
	summary     string  `json:"summary"`
	highlight   string  `json:"highlight"`
	score       float64 `json:"score"`
}

type SearchResponse {
	list []SearchResultItem `json:"list"`
}

type HealthResponse {
	status  string `json:"status"`
	service string `json:"service"`
}

type Tag {
	id          int64  `json:"id"`
	name        string `json:"name"`
	slug        string `json:"slug"`
	color       string `json:"color"`
	description string `json:"description"`
}

type TagListResponse {
	list []Tag `json:"list"`
}

type CreateTagRequest {
	name        string `json:"name"`
	slug        string `json:"slug"`
	color       string `json:"color,optional"`
	description string `json:"description,optional"`
}

type TagPathRequest {
	id int64 `path:"id"`
}

type Relation {
	id              int64  `json:"id"`
	sourceContentId int64  `json:"sourceContentId"`
	targetContentId int64  `json:"targetContentId"`
	relationType    string `json:"relationType"`
	weight          int32  `json:"weight"`
	note            string `json:"note"`
}

type RelationListResponse {
	list []Relation `json:"list"`
}

type ContentRelationsPathRequest {
	id int64 `path:"id"`
}

type CreateRelationRequest {
	contentId       int64  `path:"id"`
	targetContentId int64  `json:"targetContentId"`
	relationType    string `json:"relationType"`
	weight          int32  `json:"weight,optional"`
	note            string `json:"note,optional"`
}

type RelationPathRequest {
	id int64 `path:"id"`
}

type Attachment {
	id              int64  `json:"id"`
	contentId       int64  `json:"contentId"`
	storageProvider string `json:"storageProvider"`
	bucket          string `json:"bucket"`
	objectKey       string `json:"objectKey"`
	fileName        string `json:"fileName"`
	mimeType        string `json:"mimeType"`
	ext             string `json:"ext"`
	sizeBytes       int64  `json:"sizeBytes"`
	usageType       string `json:"usageType"`
}

type AttachmentListRequest {
	contentId int64 `form:"contentId,optional"`
	page      int64 `form:"page,optional"`
	pageSize  int64 `form:"pageSize,optional"`
}

type AttachmentListResponse {
	list []Attachment `json:"list"`
}

type CreateAttachmentRequest {
	contentId       int64  `json:"contentId"`
	storageProvider string `json:"storageProvider,optional"`
	bucket          string `json:"bucket,optional"`
	objectKey       string `json:"objectKey"`
	fileName        string `json:"fileName"`
	mimeType        string `json:"mimeType,optional"`
	ext             string `json:"ext,optional"`
	sizeBytes       int64  `json:"sizeBytes,optional"`
	usageType       string `json:"usageType,optional"`
}

type AttachmentPathRequest {
	id int64 `path:"id"`
}

type Comment {
	id              int64  `json:"id"`
	contentId       int64  `json:"contentId"`
	parentCommentId int64  `json:"parentCommentId"`
	authorName      string `json:"authorName"`
	authorEmail     string `json:"authorEmail"`
	bodyMarkdown    string `json:"bodyMarkdown"`
	status          string `json:"status"`
	moderationNote  string `json:"moderationNote"`
}

type CommentListRequest {
	contentId int64 `path:"id"`
	page      int64 `form:"page,optional"`
	pageSize  int64 `form:"pageSize,optional"`
}

type CommentListResponse {
	list []Comment `json:"list"`
}

type CreateCommentRequest {
	contentId       int64  `path:"id"`
	parentCommentId int64  `json:"parentCommentId,optional"`
	authorName      string `json:"authorName,optional"`
	authorEmail     string `json:"authorEmail,optional"`
	bodyMarkdown    string `json:"bodyMarkdown"`
}

type UpdateCommentStatusRequest {
	id             int64  `path:"id"`
	status         string `json:"status"`
	moderationNote string `json:"moderationNote,optional"`
}

type SearchIndexPathRequest {
	id int64 `path:"id"`
}

type SearchIndexDocument {
	contentId   int64  `json:"contentId"`
	contentType string `json:"type"`
	title       string `json:"title"`
	slug        string `json:"slug"`
	status      string `json:"status"`
	visibility  string `json:"visibility"`
	indexedAt   string `json:"indexedAt"`
}

@server (
	prefix: /api/v2
	group:  gateway
)
service gateway-api {
	@handler Healthz
	get /healthz returns (HealthResponse)

	@handler Me
	get /auth/me returns (UserProfile)

	@handler ListContents
	get /studio/contents (ContentListRequest) returns (ContentListResponse)

	@handler CreateContent
	post /studio/contents (ContentCreateRequest) returns (ContentDetail)

	@handler GetContent
	get /studio/contents/:id (ContentPathRequest) returns (ContentDetail)

	@handler UpdateContent
	put /studio/contents/:id (ContentUpdateRequest) returns (ContentDetail)

	@handler UpdateContentStatus
	put /studio/contents/:id/status (StatusUpdateRequest) returns (ContentDetail)

	@handler ListRevisions
	get /studio/contents/:id/revisions (RevisionListRequest) returns (RevisionListResponse)

	@handler GetRevision
	get /studio/contents/:id/revisions/:revisionId (RevisionPathRequest) returns (RevisionDetail)

	@handler RestoreRevision
	post /studio/contents/:id/revisions/:revisionId/restore (RevisionPathRequest) returns (ContentDetail)

	@handler ListReviews
	get /studio/reviews (ReviewListRequest) returns (ReviewListResponse)

	@handler SubmitReview
	post /studio/contents/:id/reviews/submit (ContentReviewSubmitRequest) returns (ReviewTask)

	@handler ApproveReview
	post /studio/reviews/:id/approve (ReviewDecisionRequest) returns (ReviewTask)

	@handler RejectReview
	post /studio/reviews/:id/reject (ReviewDecisionRequest) returns (ReviewTask)

	@handler ListTags
	get /studio/tags returns (TagListResponse)

	@handler CreateTag
	post /studio/tags (CreateTagRequest) returns (Tag)

	@handler DeleteTag
	delete /studio/tags/:id (TagPathRequest)

	@handler ListRelations
	get /studio/contents/:id/relations (ContentRelationsPathRequest) returns (RelationListResponse)

	@handler CreateRelation
	post /studio/contents/:id/relations (CreateRelationRequest) returns (Relation)

	@handler DeleteRelation
	delete /studio/relations/:id (RelationPathRequest)

	@handler ListAttachments
	get /studio/attachments (AttachmentListRequest) returns (AttachmentListResponse)

	@handler CreateAttachment
	post /studio/attachments (CreateAttachmentRequest) returns (Attachment)

	@handler DeleteAttachment
	delete /studio/attachments/:id (AttachmentPathRequest)

	@handler ListComments
	get /studio/contents/:id/comments (CommentListRequest) returns (CommentListResponse)

	@handler CreateComment
	post /studio/contents/:id/comments (CreateCommentRequest) returns (Comment)

	@handler UpdateCommentStatus
	put /studio/comments/:id/status (UpdateCommentStatusRequest) returns (Comment)

	@handler StudioQuery
	get /studio/search/query (SearchRequest) returns (SearchResponse)

	@handler ReindexContent
	post /studio/search/index/contents/:id (SearchIndexPathRequest) returns (SearchIndexDocument)

	@handler DeleteSearchIndex
	delete /studio/search/index/contents/:id (SearchIndexPathRequest)
}
